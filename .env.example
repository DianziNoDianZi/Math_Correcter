# 管理员账户配置
ADMIN_USER=admin
ADMIN_PASS=changeme

# Flask 安全配置
SECRET_KEY=your-secret-key-here-change-in-production

# 服务器端口
PORT=8000

# CORS 支持（设置为 true 以启用跨域请求）
CORS_ENABLED=false

# 速率限制配置
RATE_LIMIT_ENABLED=true
# 时间窗口（秒）
RATE_LIMIT_WINDOW=60
# 每个窗口允许的最大请求数
RATE_LIMIT_MAX=30

# 任务保留配置（天）
TASK_RETENTION_DAYS=7
